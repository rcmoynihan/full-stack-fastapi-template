# Local Development Only
# Copy this file to .env and customize as needed.
# Staging and production use platform secrets, not this file.

PROJECT_NAME="Full Stack FastAPI Project"
ENVIRONMENT=local

# Supabase Auth local defaults. `scripts/supabase-local.sh start` writes
# local secret values to ignored `.env.supabase.local`.
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_AUTH_URL=http://127.0.0.1:55321
SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=http://127.0.0.1:55321/auth/v1
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_ID=00000000-0000-4000-8000-000000000001
FIRST_SUPERUSER_PASSWORD=changethis

# Postgres defaults match the Docker Compose db service.
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_HOST_PORT=55432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Frontend and CORS
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://127.0.0.1:5173"

SENTRY_DSN=
