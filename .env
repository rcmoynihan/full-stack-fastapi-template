# Local Development Only
# Staging and production use platform secrets, not this file.

PROJECT_NAME="Full Stack FastAPI Project"
ENVIRONMENT=local

# Backend secrets
SECRET_KEY=changethis-dev-only
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Postgres defaults match the Docker Compose db service.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Frontend and CORS
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"

# SMTP is optional locally. Compose overrides SMTP_HOST for mailcatcher.
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

SENTRY_DSN=
